{
  "name": "virtualdeck",
  "version": "0.4.0",
  "description": "VirtualDeck – Stream Deck alternativo para Windows",
  "main": "out/main/index.js",
  "private": true,
  "author": "Andy Villatoro <noc@metronethn.com>",
  "license": "UNLICENSED",
  "homepage": "https://github.com/AndyVillatoro/virtualdeck",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndyVillatoro/virtualdeck.git"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-builder --win --dir",
    "build:icon": "node scripts/generate-icon.js",
    "build:installer": "electron-vite build && electron-builder --win nsis",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:arch": "depcruise src electron",
    "lint:dead": "knip",
    "check": "tsc --noEmit && depcruise src electron && eslint ."
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.8.0",
    "openrgb-sdk": "^0.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "dependency-cruiser": "^17.4.3",
    "electron": "^33.4.11",
    "electron-builder": "^24.9.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "knip": "^6.14.2",
    "sharp": "^0.34.5",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.virtualdeck.app",
    "productName": "VirtualDeck",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "AndyVillatoro",
        "repo": "virtualdeck"
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/uiohook-napi/**"
    ],
    "extraResources": [
      {
        "from": "resources/lhm",
        "to": "lhm",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "VirtualDeck-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VirtualDeck",
      "uninstallDisplayName": "VirtualDeck ${version}",
      "deleteAppDataOnUninstall": false
    }
  }
}
